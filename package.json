{
  "name": "backping",
  "version": "1.0.1",
  "description": "A local macOS menu-bar app that lets coding agents ask the user for input over chat.",
  "homepage": "https://sitaramshelke.me/backping/",
  "repository": {
    "type": "git",
    "url": "https://github.com/sitaramshelke/backping.git"
  },
  "bugs": {
    "url": "https://github.com/sitaramshelke/backping/issues"
  },
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/build-icons.mjs",
    "package:mac": "npm run build && electron-builder --mac dir --publish never",
    "dmg": "npm run package:mac && node scripts/create-dmg.mjs"
  },
  "keywords": [
    "mcp",
    "codex",
    "telegram",
    "human-in-the-loop",
    "electron"
  ],
  "author": "sitaramshelke",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.16.0",
    "electron-store": "^11.0.2",
    "express": "^5.2.1",
    "grammy": "^1.43.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "build": {
    "appId": "dev.backping.app",
    "productName": "BackPing",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/preload.cjs",
      "src/renderer/**/*",
      "assets/**/*",
      "slack-app-manifest.example.json",
      "package.json",
      "README.md"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon/icon.icns",
      "target": [
        "dir",
        "dmg"
      ],
      "identity": null
    },
    "dmg": {
      "title": "BackPing"
    }
  }
}
